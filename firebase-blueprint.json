{
  "entities": {
    "Student": {
      "title": "Student Profile",
      "description": "Profile information for a class student",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name of the student" },
        "bio": { "type": "string", "description": "Short biography" },
        "photoURL": { "type": "string", "description": "Profile picture URL" },
        "socialLinks": {
          "type": "object",
          "properties": {
            "instagram": { "type": "string" },
            "twitter": { "type": "string" },
            "linkedin": { "type": "string" },
            "github": { "type": "string" },
            "spotify": { "type": "string" }
          }
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "publicKey": { "type": "string", "description": "RSA Public Key for E2EE" }
      },
      "required": ["uid", "name"]
    },
    "Project": {
      "title": "Student Project",
      "description": "A project uploaded by a student",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageURL": { "type": "string" },
        "link": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "authorUid", "authorName"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "A photo uploaded to the class gallery",
      "type": "object",
      "properties": {
        "imageURL": { "type": "string" },
        "caption": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "uploaderName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "aspectRatio": { "type": "string", "enum": ["portrait", "landscape", "square"] }
      },
      "required": ["imageURL", "uploadedBy", "uploaderName"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "A class announcement",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "author": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "enum": ["whatsapp", "web"] }
      },
      "required": ["content", "author"]
    },
    "ChatRoom": {
      "title": "Chat Room",
      "description": "A private conversation between two users",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "updatedAt"]
    },
    "DirectMessage": {
      "title": "Direct Message",
      "description": "An end-to-end encrypted message",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "encryptedContent": { "type": "string" },
        "encryptedKeyForSender": { "type": "string" },
        "encryptedKeyForReceiver": { "type": "string" },
        "iv": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "type": { "type": "string", "enum": ["text", "image", "file", "audio"] },
        "fileName": { "type": "string" },
        "fileSize": { "type": "number" },
        "audioDuration": { "type": "number" }
      },
      "required": ["senderId", "receiverId", "encryptedContent", "iv", "createdAt", "type"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Collection of student profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of student projects"
    },
    "/gallery/{itemId}": {
      "schema": "GalleryItem",
      "description": "Collection of gallery photos"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Collection of announcements"
    },
    "/chatRooms/{roomId}": {
      "schema": "ChatRoom",
      "description": "Collection of private chat rooms"
    },
    "/chatRooms/{roomId}/messages/{messageId}": {
      "schema": "DirectMessage",
      "description": "Messages within a chat room"
    }
  }
}
