rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: students
    // Document ID: {studentId} (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - bio: string
    //   - photoURL: string
    //   - socialLinks: map
    //   - tags: list
    //   - role: string (student|admin)
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - title: string (required)
    //   - description: string
    //   - imageURL: string
    //   - link: string
    //   - authorUid: string (required)
    //   - authorName: string (required)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "vvek34785@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['uid', 'name']) &&
             data.uid is string &&
             data.name is string && data.name.size() < 100 &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 500)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1000)) &&
             (!('socialLinks' in data) || (data.socialLinks is map && 
               (!('instagram' in data.socialLinks) || data.socialLinks.instagram is string) &&
               (!('twitter' in data.socialLinks) || data.socialLinks.twitter is string) &&
               (!('snapchat' in data.socialLinks) || data.socialLinks.snapchat is string) &&
               (!('discord' in data.socialLinks) || data.socialLinks.discord is string) &&
               (!('youtube' in data.socialLinks) || data.socialLinks.youtube is string) &&
               (!('linkedin' in data.socialLinks) || data.socialLinks.linkedin is string) &&
               (!('github' in data.socialLinks) || data.socialLinks.github is string)
             ));
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'authorUid', 'authorName']) &&
             data.title is string && data.title.size() < 100 &&
             data.authorUid is string &&
             data.authorName is string &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000));
    }

    // Rules
    match /students/{studentId} {
      allow read: if true; // Publicly readable profiles
      allow create: if isAuthenticated() && isOwner(studentId) && isValidStudent(request.resource.data);
      allow update: if (isOwner(studentId) || isAdmin()) && isValidStudent(request.resource.data);
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid && isValidProject(request.resource.data);
      allow update: if (isAuthenticated() && resource.data.authorUid == request.auth.uid && isValidProject(request.resource.data)) || isAdmin();
      allow delete: if (isAuthenticated() && resource.data.authorUid == request.auth.uid) || isAdmin();
    }
  }
}
